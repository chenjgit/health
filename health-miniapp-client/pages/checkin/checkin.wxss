@import "../../app.wxss";

.checkin-status {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  text-align: center;
  padding: 30rpx 20rpx;
}

.status-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.streak-num {
  font-size: 48rpx;
  font-weight: 700;
}

.streak-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.checked-badge {
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  padding: 10rpx 30rpx;
  display: inline-block;
  font-size: 26rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.input {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
}

.picker {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.textarea {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  min-height: 120rpx;
}

.primary {
  margin-top: 20rpx;
  background: #22c55e;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.history-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.history-detail {
  font-size: 28rpx;
  color: #374151;
}

.page {
  padding-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.sub {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.field {
  margin-top: 18rpx;
}

.label {
  color: #111827;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.input,
.picker {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.primary {
  margin-top: 24rpx;
  background: #22c55e;
  color: #ffffff;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.calendar-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #bbf7d0;
  font-size: 40rpx;
}

.calendar-week {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.week-cell {
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
}

.calendar-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  height: 74rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.day-cell.muted {
  opacity: 0.45;
}

.day-cell.today {
  border-color: #22c55e;
}

.day-num {
  font-size: 26rpx;
  color: #111827;
}

.day-dot {
  margin-top: 6rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #22c55e;
}

