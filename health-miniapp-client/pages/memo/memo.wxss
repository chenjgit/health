@import "../../app.wxss";

.page {
  padding-bottom: 40rpx;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #111827;
}

.sub {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.tab-row {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  background: #f3f4f6;
  color: #374151;
  font-size: 28rpx;
  font-weight: 700;
}

.tab.active {
  background: #22c55e;
  color: #ffffff;
}

.input {
  width: 100%;
  margin-top: 14rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  font-size: 28rpx;
  color: #111827;
}

.textarea {
  width: 100%;
  margin-top: 14rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  font-size: 28rpx;
  color: #111827;
  min-height: 160rpx;
}

.row {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.picker {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #bbf7d0;
  font-size: 28rpx;
  font-weight: 700;
}

.primary {
  margin-top: 16rpx;
  background: #22c55e;
  color: #ffffff;
}

.ghost {
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #bbf7d0;
}

.mini {
  padding: 0 18rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  margin-top: 0;
}

.list-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 2rpx solid #f3f4f6;
}

.list-main {
  flex: 1;
}

.list-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.list-sub {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
  max-height: 64rpx;
  overflow: hidden;
}

.timer-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 2rpx solid #f3f4f6;
}

.timer-main {
  flex: 1;
}

.timer-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.timer-sub {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.timer-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
