@import "../../app.wxss";

.page {
  padding-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.sub {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.label {
  color: #111827;
  font-size: 28rpx;
  font-weight: 500;
}

.value {
  color: #374151;
  font-size: 28rpx;
  max-width: 420rpx;
  text-align: right;
  word-break: break-all;
}

.input {
  margin-top: 14rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  font-size: 28rpx;
}

.actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.ghost {
  flex: 1;
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #bbf7d0;
}

.primary {
  flex: 1;
  background: #22c55e;
  color: #ffffff;
}

.tips {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 38rpx;
}

