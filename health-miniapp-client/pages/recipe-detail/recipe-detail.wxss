@import "../../app.wxss";

.page {
  padding-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.meta {
  margin-top: 10rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.summary {
  margin-top: 14rpx;
  color: #374151;
  font-size: 28rpx;
  line-height: 1.6;
}

.meta2 {
  margin-top: 10rpx;
  color: #16a34a;
  font-size: 24rpx;
}

.actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.ghost {
  flex: 1;
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #bbf7d0;
}

.cover {
  margin-top: 16rpx;
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
}

.section-header {
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.content {
  margin-top: 10rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.sub {
  color: #6b7280;
  font-size: 28rpx;
}

