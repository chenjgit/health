@import "../../app.wxss";

.page {
  padding-bottom: 40rpx;
}

.news-swiper {
  margin-top: 16rpx;
  height: 180rpx;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item-content {
  flex: 1;
}

.news-arrow {
  font-size: 36rpx;
  color: #9ca3af;
  margin-left: 12rpx;
}

.news-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.news-hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #22c55e;
}

.tip-title {
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.tip-content {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #374151;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.sub {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.quick-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.ghost {
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #bbf7d0;
}

.search {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  font-size: 28rpx;
}

.search-btn {
  background: #22c55e;
  color: #ffffff;
}

.article-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.article-main {
  flex: 1;
}

.article-title {
  font-size: 32rpx;
  font-weight: 600;
}

.article-summary {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 28rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  margin-top: 12rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.article-cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

