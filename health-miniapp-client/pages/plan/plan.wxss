@import "../../app.wxss";

.page {
  padding-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sub {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.primary-mini {
  background: #22c55e;
  color: #ffffff;
}

.field {
  margin-top: 18rpx;
}

.label {
  color: #111827;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.input {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.actions {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.ghost {
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #bbf7d0;
}

.primary {
  background: #22c55e;
  color: #ffffff;
  border: none;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 600;
}

.plan-meta {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.plan-summary {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.plan-content {
  margin-top: 10rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f3f4f6;
}

.reminder-row:last-child {
  border-bottom: none;
}

.reminder-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reminder-name {
  font-size: 28rpx;
  color: #111827;
}

.reminder-time {
  font-size: 28rpx;
  color: #15803d;
  font-weight: 600;
  padding: 6rpx 16rpx;
  background: #f0fdf4;
  border-radius: 8rpx;
}

