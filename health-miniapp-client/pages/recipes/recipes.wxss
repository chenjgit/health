@import "../../app.wxss";

.page {
  padding-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.sub {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.search {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  font-size: 28rpx;
}

.search-btn {
  background: #22c55e;
  color: #ffffff;
}

.filters {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e5e7eb;
  font-size: 24rpx;
  color: #374151;
  background: #f9fafb;
}

.recipe-row {
  display: flex;
  gap: 16rpx;
}

.recipe-main {
  flex: 1;
}

.recipe-name {
  font-size: 32rpx;
  font-weight: 600;
}

.recipe-summary {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 28rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-meta {
  margin-top: 10rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.recipe-cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

